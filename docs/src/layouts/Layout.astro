---
import { getCollection } from 'astro:content';
import { parseComponent } from '../utils/component.js';
import '../styles/global.css';

const { title, description = 'Copy-pasteable Stimulus JS controllers for Ruby on Rails.', currentSlug } =
  Astro.props;

const allComponents = await getCollection('components');
const navItems = allComponents
  .map(parseComponent)
  .sort((a, b) => a.name.localeCompare(b.name));

const siteUrl = Astro.site?.origin ?? 'https://stimulus-snippets.dev';
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;
const pageTitle = title ? `${title} — stimulus-snippets` : 'stimulus-snippets — Stimulus JS Controllers for Rails';
const ogTitle = title ? `${title} — Stimulus JS` : 'stimulus-snippets — Stimulus JS Controllers for Rails';

const jsonLd = (
  currentSlug
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'TechArticle',
        name: title,
        description,
        url: pageUrl,
        isPartOf: {
          '@type': 'WebSite',
          name: 'stimulus-snippets',
          url: siteUrl,
        },
      })
    : JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'stimulus-snippets',
        description,
        url: siteUrl,
      })
).replace(/</g, '\\u003c');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Open Graph -->
    <meta property="og:type" content={currentSlug ? 'article' : 'website'} />
    <meta property="og:site_name" content="stimulus-snippets" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <!-- Structured data -->
    <script type="application/ld+json" set:html={jsonLd} />
    <!-- Prevent flash of wrong theme before CSS loads -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar">
        <div class="sidebar-inner">
          <a href="/" class="logo">
            <span class="logo-primary">stimulus</span><span class="logo-secondary">-snippets</span>
          </a>
          <nav aria-label="Guides">
            <p class="nav-label">Guides</p>
            <ul>
              <li>
                <a
                  href="/guides/getting-started"
                  class:list={['nav-link', { active: currentSlug === 'guides/getting-started' }]}
                  aria-current={currentSlug === 'guides/getting-started' ? 'page' : undefined}
                >
                  Setting up Rails with Stimulus
                </a>
              </li>
            </ul>
          </nav>
          <nav aria-label="Components">
            <p class="nav-label">Components</p>
            <ul>
              {
                navItems.map(({ slug, name }) => (
                  <li>
                    <a
                      href={`/${slug}`}
                      class:list={['nav-link', { active: slug === currentSlug }]}
                      aria-current={slug === currentSlug ? 'page' : undefined}
                    >
                      {name}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
          <nav aria-label="More">
            <ul>
              <li>
                <a
                  href="/all"
                  class:list={['nav-link', { active: currentSlug === 'all' }]}
                  aria-current={currentSlug === 'all' ? 'page' : undefined}
                >
                  All controllers
                </a>
              </li>
            </ul>
          </nav>
          <div class="sidebar-footer">
            <a
              href="https://github.com/craigmcn/stimulus-snippets"
              class="github-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"
                ></path>
              </svg>
              GitHub
            </a>
            <div class="theme-toggle" role="group" aria-label="Theme">
              <button data-theme-btn="light" aria-label="Light theme" title="Light">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="5"></circle>
                  <line x1="12" y1="1" x2="12" y2="3"></line>
                  <line x1="12" y1="21" x2="12" y2="23"></line>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                  <line x1="1" y1="12" x2="3" y2="12"></line>
                  <line x1="21" y1="12" x2="23" y2="12"></line>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
              </button>
              <button data-theme-btn="system" aria-label="System theme" title="System">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                  <line x1="8" y1="21" x2="16" y2="21"></line>
                  <line x1="12" y1="17" x2="12" y2="21"></line>
                </svg>
              </button>
              <button data-theme-btn="dark" aria-label="Dark theme" title="Dark">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </aside>
      <main class="content">
        <slot />
      </main>
    </div>
    <script>
      function applyTheme(theme: string) {
        if (theme === 'system') {
          document.documentElement.removeAttribute('data-theme');
        } else {
          document.documentElement.setAttribute('data-theme', theme);
        }
        document.querySelectorAll<HTMLElement>('[data-theme-btn]').forEach((btn) => {
          btn.classList.toggle('active', btn.dataset.themeBtn === theme);
        });
      }

      const saved = localStorage.getItem('theme') ?? 'system';
      applyTheme(saved);

      document.querySelectorAll<HTMLElement>('[data-theme-btn]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const theme = btn.dataset.themeBtn!;
          localStorage.setItem('theme', theme);
          applyTheme(theme);
        });
      });
    </script>
  </body>
</html>
