---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { parseComponent } from '../utils/component.js';

const items = (await getCollection('components')).map(parseComponent).sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="">
  <div class="hero">
    <h1>stimulus-snippets</h1>
    <p class="hero-desc">
      Copy-pasteable Stimulus JS controllers for Ruby on Rails. Inspired by <a
        href="https://ui.shadcn.com">shadcn/ui</a
      > — not an installable package, just files you own.
    </p>
  </div>

  <p class="section-label">Components</p>
  <div class="component-grid">
    {
      items.map(({ slug, name, description }) => (
        <a href={`/${slug}`} class="component-card">
          <strong>{name}</strong>
          <p>{description}</p>
        </a>
      ))
    }
  </div>
</Layout>
